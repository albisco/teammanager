generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Club {
  id                         String   @id @default(cuid())
  name                       String
  slug                       String   @unique
  logoUrl                    String?
  isAdultClub                Boolean  @default(false)
  allowTeamDutyRoles         Boolean  @default(false)
  enforceFamilyVoteExclusion Boolean  @default(false)
  maxVotesPerRound           Int      @default(4)
  enableAiChat               Boolean  @default(true)
  enablePlayHq               Boolean  @default(true)
  votingScheme               Json     @default("[5,4,3,2,1]")
  parentVoterCount           Int      @default(3)
  coachVoterCount            Int      @default(1)
  enableRoster               Boolean  @default(true)
  enableAwards               Boolean  @default(true)
  createdAt                  DateTime @default(now())

  users     User[]
  seasons   Season[]
  players   Player[]
  dutyRoles DutyRole[]
}

enum Role {
  SUPER_ADMIN
  ADMIN
  TEAM_MANAGER
  FAMILY
}

enum VotingStatus {
  OPEN
  CLOSED
}

enum VoterType {
  PARENT
  COACH
  PLAYER
}

enum AvailabilityStatus {
  AVAILABLE
  MAYBE
  UNAVAILABLE
}

enum DutyRoleType {
  FIXED
  SPECIALIST
  ROTATING
  FREQUENCY
}

enum TeamStaffRole {
  HEAD_COACH
  TEAM_MANAGER
  ASSISTANT_COACH
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(FAMILY)
  name         String
  clubId       String?
  club         Club?    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  players              Player[]
  votes                Vote[]
  managedTeams         Team[]               @relation("TeamManager")
  mcpTokens            McpToken[]
  teamStaffRoles       TeamStaff[]          @relation("TeamStaffUser")
}

model McpToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  tokenHash  String    @unique
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

model Player {
  id           String   @id @default(cuid())
  jumperNumber Int
  firstName    String
  surname      String
  dateOfBirth  DateTime?
  phone        String?
  contactEmail String?
  parent1      String?
  parent2      String?
  spare1       String?
  spare2       String?
  familyId     String?
  family       User?    @relation(fields: [familyId], references: [id])
  clubId       String
  club         Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  teamPlayers           TeamPlayer[]
  unavailabilities      PlayerUnavailability[]
  playerAvailabilities  PlayerAvailability[]
  awards                Award[]
}

model Season {
  id     String @id @default(cuid())
  name   String
  year   Int
  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  teams Team[]
}

model Team {
  id               String @id @default(cuid())
  name             String
  ageGroup         String
  seasonId         String
  season           Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  managerId        String?
  manager          User?  @relation("TeamManager", fields: [managerId], references: [id])
  votingScheme      Json   @default("[5,4,3,2,1]")
  parentVoterCount  Int    @default(3)
  coachVoterCount   Int    @default(1)
  selfManaged       Boolean @default(false)
  enableRoster      Boolean @default(true)
  enableAwards      Boolean @default(true)
  availabilityToken       String? @unique @default(cuid())
  playerAvailabilityToken String? @unique @default(cuid())
  fixtureSourceUrl        String?
  fixtureSyncedAt         DateTime?

  players               TeamPlayer[]
  rounds                Round[]
  teamDutyRoles         TeamDutyRole[]
  dutyRoles             DutyRole[]
  dutyRoleExclusions    TeamDutyRoleExclusion[]
  awardTypes            AwardType[]
  staff                 TeamStaff[]
}

model TeamStaff {
  id          String        @id @default(cuid())
  teamId      String
  team        Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?         @relation("TeamStaffUser", fields: [userId], references: [id], onDelete: SetNull)
  role        TeamStaffRole
  displayName String?
  createdAt   DateTime      @default(now())

  @@unique([teamId, userId])
  @@index([userId])
  @@index([teamId, role])
}

model TeamPlayer {
  id       String @id @default(cuid())
  teamId   String
  team     Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([teamId, playerId])
}

model Round {
  id               String    @id @default(cuid())
  teamId           String
  team             Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  roundNumber      Int
  date             DateTime?
  gameTime         String?
  isBye            Boolean   @default(false)
  opponent         String?
  venue            String?
  court            String?
  externalId       String?
  isRosterLocked   Boolean   @default(false)

  votingSession          VotingSession?
  rosterAssignments      RosterAssignment[]
  familyUnavailabilities FamilyUnavailability[]
  playerUnavailabilities PlayerUnavailability[]
  playerAvailabilities   PlayerAvailability[]
  awards                 Award[]

  @@unique([teamId, roundNumber])
  @@unique([teamId, externalId])
}

model VotingSession {
  id      String       @id @default(cuid())
  roundId String       @unique
  round   Round        @relation(fields: [roundId], references: [id], onDelete: Cascade)
  status  VotingStatus @default(OPEN)
  qrToken String       @unique @default(cuid())

  votes Vote[]
}

model Vote {
  id              String        @id @default(cuid())
  votingSessionId String
  votingSession   VotingSession @relation(fields: [votingSessionId], references: [id], onDelete: Cascade)
  voterId         String
  voter           User          @relation(fields: [voterId], references: [id], onDelete: Cascade)
  voterType       VoterType
  rankings        Json
  submittedAt     DateTime      @default(now())

  @@unique([votingSessionId, voterId])
}

model DutyRole {
  id            String         @id @default(cuid())
  roleName      String
  sortOrder     Int            @default(0)
  clubId        String
  club          Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  teamId        String?
  team          Team?          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  isVotingRole  Boolean        @default(false)
  teamStaffRole TeamStaffRole?

  teamDutyRoles TeamDutyRole[]

  @@unique([clubId, teamId, roleName])
  @@index([teamId])
}

model TeamDutyRole {
  id                 String       @id @default(cuid())
  teamId             String
  team               Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  dutyRoleId         String
  dutyRole           DutyRole     @relation(fields: [dutyRoleId], references: [id], onDelete: Cascade)
  roleType           DutyRoleType @default(ROTATING)
  assignedPersonName String?
  assignedFamilyId   String?
  frequencyWeeks     Int          @default(1)
  slots              Int          @default(1)

  specialists       TeamDutyRoleSpecialist[]
  rosterAssignments RosterAssignment[]
  familyExclusions  FamilyExclusion[]

  @@unique([teamId, dutyRoleId])
}

model TeamDutyRoleSpecialist {
  id             String       @id @default(cuid())
  teamDutyRoleId String
  teamDutyRole   TeamDutyRole @relation(fields: [teamDutyRoleId], references: [id], onDelete: Cascade)
  personName     String
  familyId       String?

  @@unique([teamDutyRoleId, personName])
}

model RosterAssignment {
  id                   String       @id @default(cuid())
  roundId              String
  round                Round        @relation(fields: [roundId], references: [id], onDelete: Cascade)
  teamDutyRoleId       String
  teamDutyRole         TeamDutyRole @relation(fields: [teamDutyRoleId], references: [id], onDelete: Cascade)
  assignedFamilyId     String?
  assignedFamilyName   String?
  assignedPersonName   String?
  slot                 Int          @default(0)

  @@unique([roundId, teamDutyRoleId, slot])
}

model TeamDutyRoleExclusion {
  id         String @id @default(cuid())
  teamId     String
  dutyRoleId String
  team       Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, dutyRoleId])
  @@index([teamId])
}

model FamilyExclusion {
  id             String       @id @default(cuid())
  familyId       String
  teamDutyRoleId String
  teamDutyRole   TeamDutyRole @relation(fields: [teamDutyRoleId], references: [id], onDelete: Cascade)

  @@unique([familyId, teamDutyRoleId])
}

model FamilyUnavailability {
  id       String @id @default(cuid())
  familyId String
  roundId  String
  round    Round  @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([familyId, roundId])
}

model PlayerUnavailability {
  id       String @id @default(cuid())
  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  roundId  String
  round    Round  @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([playerId, roundId])
}

model PlayerAvailability {
  id       String             @id @default(cuid())
  playerId String
  player   Player             @relation(fields: [playerId], references: [id], onDelete: Cascade)
  roundId  String
  round    Round              @relation(fields: [roundId], references: [id], onDelete: Cascade)
  status   AvailabilityStatus

  @@unique([playerId, roundId])
}

model AwardType {
  id          String  @id @default(cuid())
  teamId      String
  team        Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name        String
  description String?
  quantity    Int     @default(1)
  awards      Award[]

  @@unique([teamId, name])
}

model Award {
  id          String    @id @default(cuid())
  roundId     String
  round       Round     @relation(fields: [roundId], references: [id], onDelete: Cascade)
  awardTypeId String
  awardType   AwardType @relation(fields: [awardTypeId], references: [id], onDelete: Cascade)
  playerId    String
  player      Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  slot        Int       @default(0)
  notes       String?
  createdAt   DateTime  @default(now())

  @@unique([roundId, awardTypeId, slot])
}
