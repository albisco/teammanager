generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  FAMILY
}

enum VotingStatus {
  OPEN
  CLOSED
}

enum VoterType {
  PARENT
  COACH
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(FAMILY)
  name         String
  createdAt    DateTime @default(now())

  players              Player[]
  votes                Vote[]
  dutyRoleFixedAssignments DutyRoleFixed[]
  rosterAssignments    RosterAssignment[]
  familyExclusions     FamilyExclusion[]
  familyUnavailabilities FamilyUnavailability[]
}

model Player {
  id           String   @id @default(cuid())
  jumperNumber Int
  firstName    String
  surname      String
  dateOfBirth  DateTime?
  phone        String?
  contactEmail String?
  parent1      String?
  parent2      String?
  spare1       String?
  spare2       String?
  familyId     String?
  family       User?    @relation(fields: [familyId], references: [id])

  teamPlayers      TeamPlayer[]
  unavailabilities PlayerUnavailability[]
}

model Season {
  id    String @id @default(cuid())
  name  String
  year  Int

  teams Team[]
}

model Team {
  id               String @id @default(cuid())
  name             String
  ageGroup         String
  seasonId         String
  season           Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  votingScheme     Json   @default("[5,4,3,2,1]")
  parentVoterCount Int    @default(3)
  coachVoterCount  Int    @default(1)

  players         TeamPlayer[]
  rounds          Round[]
  dutyRolesFixed  DutyRoleFixed[]
  dutyRolesParent DutyRoleParent[]
}

model TeamPlayer {
  id       String @id @default(cuid())
  teamId   String
  team     Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([teamId, playerId])
}

model Round {
  id          String   @id @default(cuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  roundNumber Int
  date        DateTime?
  isBye       Boolean  @default(false)
  opponent    String?
  venue       String?

  votingSession          VotingSession?
  rosterAssignments      RosterAssignment[]
  familyUnavailabilities FamilyUnavailability[]
  playerUnavailabilities PlayerUnavailability[]

  @@unique([teamId, roundNumber])
}

model VotingSession {
  id      String       @id @default(cuid())
  roundId String       @unique
  round   Round        @relation(fields: [roundId], references: [id], onDelete: Cascade)
  status  VotingStatus @default(OPEN)
  qrToken String       @unique @default(cuid())

  votes Vote[]
}

model Vote {
  id              String        @id @default(cuid())
  votingSessionId String
  votingSession   VotingSession @relation(fields: [votingSessionId], references: [id], onDelete: Cascade)
  voterId         String
  voter           User          @relation(fields: [voterId], references: [id])
  voterType       VoterType
  rankings        Json
  submittedAt     DateTime      @default(now())

  @@unique([votingSessionId, voterId])
}

model DutyRoleFixed {
  id             String @id @default(cuid())
  teamId         String
  team           Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  roleName       String
  assignedUserId String
  assignedUser   User   @relation(fields: [assignedUserId], references: [id])
}

model DutyRoleParent {
  id       String @id @default(cuid())
  roleName String
  teamId   String
  team     Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  rosterAssignments RosterAssignment[]
  familyExclusions  FamilyExclusion[]
}

model RosterAssignment {
  id               String         @id @default(cuid())
  roundId          String
  round            Round          @relation(fields: [roundId], references: [id], onDelete: Cascade)
  dutyRoleParentId String
  dutyRoleParent   DutyRoleParent @relation(fields: [dutyRoleParentId], references: [id], onDelete: Cascade)
  assignedFamilyId String
  assignedFamily   User           @relation(fields: [assignedFamilyId], references: [id])

  @@unique([roundId, dutyRoleParentId])
}

model FamilyExclusion {
  id               String         @id @default(cuid())
  familyId         String
  family           User           @relation(fields: [familyId], references: [id])
  dutyRoleParentId String
  dutyRoleParent   DutyRoleParent @relation(fields: [dutyRoleParentId], references: [id], onDelete: Cascade)

  @@unique([familyId, dutyRoleParentId])
}

model FamilyUnavailability {
  id       String @id @default(cuid())
  familyId String
  family   User   @relation(fields: [familyId], references: [id])
  roundId  String
  round    Round  @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([familyId, roundId])
}

model PlayerUnavailability {
  id       String @id @default(cuid())
  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  roundId  String
  round    Round  @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([playerId, roundId])
}
